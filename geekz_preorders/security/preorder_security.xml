<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Grupos de acceso ────────────────────────────────────────────── -->

    <record id="group_preorder_user" model="res.groups">
        <field name="name">GeekZ Preventas / Usuario</field>
    </record>

    <record id="group_preorder_manager" model="res.groups">
        <field name="name">GeekZ Preventas / Administrador</field>
        <field name="implied_ids" eval="[(4, ref('group_preorder_user'))]"/>
    </record>

    <!-- ── Record rules: acceso de clientes portal ────────────────────── -->

    <record id="rule_preorder_portal_own" model="ir.rule">
        <field name="name">Portal: solo ver reservas propias</field>
        <field name="model_id" ref="model_preorder_reservation"/>
        <field name="groups" eval="[(4, ref('base.group_portal'))]"/>
        <field name="domain_force">[('customer_id.user_ids', 'in', [user.id])]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">0</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">0</field>
    </record>

    <!-- ── Record rules: usuarios internos ────────────────────────────── -->

    <record id="rule_preorder_company" model="ir.rule">
        <field name="name">Preorder: filtrar por empresa</field>
        <field name="model_id" ref="model_preorder_reservation"/>
        <field name="groups" eval="[(4, ref('base.group_user'))]"/>
        <field name="domain_force">[('company_id', 'in', company_ids)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">0</field>
    </record>

    <record id="rule_preorder_unlink_manager" model="ir.rule">
        <field name="name">Preorder: solo managers pueden eliminar</field>
        <field name="model_id" ref="model_preorder_reservation"/>
        <field name="groups" eval="[(4, ref('group_preorder_manager'))]"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="perm_read">1</field>
        <field name="perm_write">1</field>
        <field name="perm_create">1</field>
        <field name="perm_unlink">1</field>
    </record>

</odoo>
