<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Extensión del formulario de producto: pestaña Preventa -->

    <record id="view_product_template_preorder" model="ir.ui.view">
        <field name="name">product.template.form.preorder</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_only_form_view"/>
        <field name="arch" type="xml">
            <notebook position="inside">
                <page string="Preventa GeekZ" name="preorder_tab">

                    <group>
                        <group string="Configuración">
                            <field name="preorder_enabled"/>
                            <field name="preorder_eta"
                                   invisible="not preorder_enabled"/>
                            <field name="preorder_max_qty_per_customer"
                                   invisible="not preorder_enabled"/>
                            <field name="preorder_limit_total"
                                   invisible="not preorder_enabled"
                                   help="0 = sin límite total de reservas"/>
                            <field name="preorder_visible_stock"
                                   invisible="not preorder_enabled"/>
                        </group>
                        <group string="Estado Actual" invisible="not preorder_enabled">
                            <field name="preorder_active_count" readonly="1"/>
                            <field name="preorder_total_qty_reserved" readonly="1"/>
                        </group>
                    </group>

                    <group string="Mensaje para el cliente" invisible="not preorder_enabled">
                        <field name="preorder_message" nolabel="1"
                               placeholder="Texto mostrado en la página del producto durante la preventa..."/>
                    </group>

                    <div invisible="not preorder_enabled" class="mt-3">
                        <button name="action_view_preorder_reservations"
                                string="Ver todas las reservas de este producto"
                                type="object" class="btn btn-secondary btn-sm"/>
                    </div>

                </page>
            </notebook>
        </field>
    </record>

    <!-- Lista de productos: columna de preventa -->

    <record id="view_product_template_preorder_list" model="ir.ui.view">
        <field name="name">product.template.tree.preorder</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="product.product_template_tree_view"/>
        <field name="arch" type="xml">
            <field name="name" position="after">
                <field name="preorder_enabled" string="Preventa"
                       optional="show" widget="boolean_toggle"/>
                <field name="preorder_eta" string="ETA" optional="show"/>
                <field name="preorder_active_count" string="Reservas"
                       optional="show"/>
            </field>
        </field>
    </record>

</odoo>
