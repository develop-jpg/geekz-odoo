<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ── Template: Stock asignado → cliente notificado ──────────────── -->

    <record id="email_template_preorder_allocated" model="mail.template">
        <field name="name">GeekZ Preventa - Stock Asignado</field>
        <field name="model_id" ref="model_preorder_reservation"/>
        <field name="subject">🎉 ¡Tu preventa llegó a bodega! — {{ object.product_id.name }}</field>
        <field name="email_from">{{ (object.company_id.email or 'ventas@geekz.cl') }}</field>
        <field name="email_to">{{ object.customer_id.email }}</field>
        <field name="lang">{{ object.customer_id.lang }}</field>
        <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; background: #f8f9fa; padding: 24px;">

    <!-- Header -->
    <div style="background: #1a1a2e; border-radius: 12px 12px 0 0; padding: 24px; text-align: center;">
        <h1 style="color: #FFCB05; margin: 0; font-size: 1.6rem; letter-spacing: 1px;">GEEKZ</h1>
        <p style="color: #adb5bd; margin: 6px 0 0; font-size: 0.9rem;">Portal de Preventas</p>
    </div>

    <!-- Contenido principal -->
    <div style="background: #ffffff; padding: 32px; border-left: 4px solid #FFCB05;">

        <p style="font-size: 1.1rem; color: #1a1a2e;">
            Hola, <strong>{{ object.customer_id.name }}</strong>
        </p>

        <p style="color: #495057;">
            ¡Buenas noticias! El producto que reservaste ha llegado a nuestra bodega
            y hemos asignado tu stock. Tienes <strong>7 días</strong> para completar
            tu compra antes de que la reserva quede disponible para el siguiente cliente.
        </p>

        <!-- Detalle reserva -->
        <div style="background: #f8f9fa; border-radius: 8px; padding: 20px; margin: 24px 0;">
            <table style="width: 100%; border-collapse: collapse;">
                <tr>
                    <td style="padding: 8px 0; color: #6c757d; font-size: 0.9rem;">Referencia</td>
                    <td style="padding: 8px 0; font-weight: bold; text-align: right;">{{ object.name }}</td>
                </tr>
                <tr>
                    <td style="padding: 8px 0; color: #6c757d; font-size: 0.9rem;">Producto</td>
                    <td style="padding: 8px 0; font-weight: bold; text-align: right;">{{ object.product_id.name }}</td>
                </tr>
                <tr>
                    <td style="padding: 8px 0; color: #6c757d; font-size: 0.9rem;">Cantidad</td>
                    <td style="padding: 8px 0; font-weight: bold; text-align: right;">{{ object.quantity }} unidad(es)</td>
                </tr>
                <tr style="border-top: 1px solid #dee2e6;">
                    <td style="padding: 12px 0 8px; color: #dc3545; font-weight: bold; font-size: 0.9rem;">⏰ Vence el</td>
                    <td style="padding: 12px 0 8px; font-weight: bold; color: #dc3545; text-align: right;">
                        {{ object.expiration_date and object.expiration_date.strftime('%d/%m/%Y %H:%M') or 'Por definir' }}
                    </td>
                </tr>
            </table>
        </div>

        <!-- CTA -->
        <div style="text-align: center; margin: 32px 0;">
            <a href="{{ ctx.get('base_url', '') }}/preorder/checkout/{{ object.id }}"
               style="background: #FFCB05; color: #1a1a2e; text-decoration: none;
                      padding: 14px 36px; border-radius: 8px; font-weight: bold;
                      font-size: 1rem; display: inline-block;">
                ✅ Completar mi compra
            </a>
        </div>

        <p style="color: #6c757d; font-size: 0.85rem; text-align: center;">
            Si no completas tu compra antes de la fecha indicada, el stock se reasignará
            automáticamente al siguiente cliente en lista de espera.
        </p>

    </div>

    <!-- Footer -->
    <div style="background: #1a1a2e; border-radius: 0 0 12px 12px; padding: 16px; text-align: center;">
        <p style="color: #6c757d; font-size: 0.8rem; margin: 0;">
            GEEKZ SPA — ventas@geekz.cl — www.geekz.cl
        </p>
    </div>

</div>
        ]]></field>
        <field name="auto_delete">True</field>
    </record>

    <!-- ── Template: Reserva confirmada al crear ───────────────────────── -->

    <record id="email_template_preorder_confirmed" model="mail.template">
        <field name="name">GeekZ Preventa - Reserva Confirmada</field>
        <field name="model_id" ref="model_preorder_reservation"/>
        <field name="subject">✅ Reserva de preventa confirmada — {{ object.product_id.name }}</field>
        <field name="email_from">{{ (object.company_id.email or 'ventas@geekz.cl') }}</field>
        <field name="email_to">{{ object.customer_id.email }}</field>
        <field name="lang">{{ object.customer_id.lang }}</field>
        <field name="body_html"><![CDATA[
<div style="font-family: Arial, sans-serif; max-width: 600px; margin: 0 auto; background: #f8f9fa; padding: 24px;">

    <div style="background: #1a1a2e; border-radius: 12px 12px 0 0; padding: 24px; text-align: center;">
        <h1 style="color: #FFCB05; margin: 0;">GEEKZ</h1>
        <p style="color: #adb5bd; margin: 6px 0 0; font-size: 0.9rem;">Confirmación de Preventa</p>
    </div>

    <div style="background: #fff; padding: 32px; border-left: 4px solid #28a745;">
        <p>Hola, <strong>{{ object.customer_id.name }}</strong></p>
        <p style="color: #495057;">
            Tu reserva de preventa ha sido confirmada exitosamente.
            Te notificaremos por email en cuanto el producto llegue a bodega.
        </p>

        <div style="background: #f8f9fa; border-radius: 8px; padding: 20px; margin: 24px 0;">
            <table style="width: 100%;">
                <tr>
                    <td style="color: #6c757d; padding: 6px 0;">Referencia</td>
                    <td style="font-weight: bold; text-align: right;">{{ object.name }}</td>
                </tr>
                <tr>
                    <td style="color: #6c757d; padding: 6px 0;">Producto</td>
                    <td style="font-weight: bold; text-align: right;">{{ object.product_id.name }}</td>
                </tr>
                <tr>
                    <td style="color: #6c757d; padding: 6px 0;">Cantidad</td>
                    <td style="font-weight: bold; text-align: right;">{{ object.quantity }}</td>
                </tr>
                <tr>
                    <td style="color: #6c757d; padding: 6px 0;">ETA</td>
                    <td style="font-weight: bold; text-align: right;">
                        {{ object.product_tmpl_id.preorder_eta or 'Por confirmar' }}
                    </td>
                </tr>
                <tr>
                    <td style="color: #6c757d; padding: 6px 0;">Posición en cola</td>
                    <td style="font-weight: bold; text-align: right;">#{{ object.queue_position }}</td>
                </tr>
            </table>
        </div>

        <p style="color: #6c757d; font-size: 0.85rem;">
            Recuerda: esta reserva no implica ningún pago. Solo te cobraremos
            cuando el producto llegue y lo hayas confirmado.
        </p>
    </div>

    <div style="background: #1a1a2e; border-radius: 0 0 12px 12px; padding: 16px; text-align: center;">
        <p style="color: #6c757d; font-size: 0.8rem; margin: 0;">GEEKZ SPA — ventas@geekz.cl</p>
    </div>

</div>
        ]]></field>
        <field name="auto_delete">True</field>
    </record>

</odoo>
